Options -Indexes
ServerSignature Off

# Protection uploads : interdire l'exécution de PHP dans le dossier uploads
<FilesMatch "\.php$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# Headers de sécurité
<IfModule mod_headers.c>
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-Content-Type-Options "nosniff"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>
